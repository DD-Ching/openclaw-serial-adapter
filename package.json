{
  "name": "serial-adapter",
  "version": "0.3.0",
  "description": "Serial device telemetry adapter plugin for OpenClaw",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "uv run pytest tests/ -x",
    "quick-check": "node scripts/quick_self_check.js",
    "postinstall": "node scripts/postinstall.mjs",
    "prepare": "husky"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.39"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "typescript": "^5.4.0"
  },
  "files": [
    "index.ts",
    "src/",
    "python/",
    "scripts/",
    "openclaw.plugin.json",
    "pyproject.toml",
    "uv.lock"
  ],
  "license": "MIT"
}
